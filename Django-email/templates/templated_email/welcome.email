{% load static %}
{% block subject %} <br>
My subject for {{ full_name }}
{% endblock %} <br> <br>

{% block plain %}
Hi {{ full_name }},

Welcome via email.

Thanks,
You rock!
{% endblock %}

{% block html %}
<p>Hi {{ full_name }},</p>

<p>Welcome via email.</p>

<img src="{% static logo %}" alt="welcome image" width="200px">

<p>Thanks,<br>
You rock!</p>
{% endblock %}  